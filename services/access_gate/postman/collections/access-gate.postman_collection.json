{
  "info": {
    "name": "Access Gate Contract Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - alive check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has service status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'ok');",
                  "  pm.expect(json).to.have.property('service', 'access-gate');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET /access/logs/recent - get recent swipe events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent?limit=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "access",
                "logs",
                "recent"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('items');",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /gates/{id}/status - get gate operational status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/gates/gate-a/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "gates",
                "gate-a",
                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has gate status details', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('gate_id', 'gate-a');",
                  "  pm.expect(json).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /cards/{uid} - lookup student card info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cards/04:A1:B2:C3:D4:03",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cards",
                "04:A1:B2:C3:D4:03"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has card registration state', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('uid', '04:A1:B2:C3:D4:03');",
                  "  pm.expect(json).to.have.property('registered');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /access/logs/recent - missing token is rejected",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/access/logs/recent",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "access",
                "logs",
                "recent"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401 Unauthorized', function () {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}

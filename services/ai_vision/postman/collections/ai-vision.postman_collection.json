{
  "info": {
    "name": "AI Vision Contract Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - alive check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has service status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'ok');",
                  "  pm.expect(json).to.have.property('service', 'ai-vision');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /detect - happy path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-a\",\n  \"image_url\": \"https://example.com/frame.jpg\",\n  \"motion_score\": 0.82\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/detect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "detect"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has detection results', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('detection_id');",
                  "  pm.expect(json).to.have.property('camera_id', 'cam-gate-a');",
                  "  pm.expect(json).to.have.property('detections');",
                  "  pm.expect(json.detections).to.be.an('array');",
                  "  pm.environment.set('lastDetectionId', json.detection_id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /vision/face-match - happy path",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-a\",\n  \"reference_face_id\": \"face-123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/vision/face-match",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vision",
                "face-match"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has face match result', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('matched');",
                  "  pm.expect(json).to.have.property('confidence');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /vision/detections/{id} - retrieve by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/vision/detections/{{lastDetectionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vision",
                "detections",
                "{{lastDetectionId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has detection detail', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('detection_id', pm.environment.get('lastDetectionId'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST /detect - missing token is rejected",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"camera_id\": \"cam-gate-a\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/detect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "detect"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401 Unauthorized', function () {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "POST /detect - missing required camera_id",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image_url\": \"https://example.com/frame.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/detect",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "detect"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns client error status 422 or 400', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
